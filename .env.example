WINDSOR_API_KEY=
DATABASE_URL=postgresql+psycopg://kfc_app_installs:kfc_app_installs@db:5432/kfc_app_installs
ALLOWED_ORIGINS=https://grupo-mkp.com,http://localhost:5173,http://localhost:8030
PUBLIC_BASE_URL=http://localhost:8030
REFRESH_CRON=*/30 * * * *
CACHE_TTL_SECONDS=900

# Local/dev mode without Azure/MSAL.
AUTH_DISABLED=true
ALLOWED_ROLES=Planners,admin

# Optional operational settings.
APP_TIMEZONE=America/Guayaquil
PUBLIC_RATE_LIMIT_REQUESTS=60
PUBLIC_RATE_LIMIT_WINDOW_SECONDS=60
CREATE_DB_ON_STARTUP=true
SCHEDULER_ENABLED=true

# Docker Compose Postgres settings.
POSTGRES_DB=kfc_app_installs
POSTGRES_USER=kfc_app_installs
POSTGRES_PASSWORD=kfc_app_installs
